  "breeding_mechanics": {
    "description": "Each Pal has a hidden 'Breeding Power' number between 1 and 1500. Lower numbers = rarer/more powerful Pals.",
    "formula": "Child_Rank = floor((ParentA_Rank + ParentB_Rank + 1) / 2)",
    "formula_explanation": "Add both parents' breeding power plus 1, divide by 2, round down to nearest whole number.",
    "result_selection": "The child species with the rank closest to this computed value is selected. If two species are equidistant, the one with the lowest internal index number wins.",
    "constraint": "You can never breed a Pal stronger/rarer (lower rank) than your strongest parent.",
    "unique_combos": "Some Pal variants override the rank system and require specific parent combinations (see unique_combinations below).",
    "same_species": "Breeding two of the same species always produces that species.",
    "variant_pals": "Pal variants (Cryst, Ignis, Noct, Lux, Aqua, Terra, Botan) have their own breeding power entries.",
    "tower_boss_pals": "Tower Boss Pals (marked with *) cannot be bred through the standard system and require specific combinations.",
    "gender": "You need one Male and one Female of opposite types. Gender ratio varies by species.",
    "cake": "At least 1 Cake must be present in the Breeding Farm chest."
  },
